---
import { SITE_TITLE } from "../consts";
import HeaderLink from "./HeaderLink.astro";
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="social-links">
			<a href="mailto:ayush25khanna@gmail.com">
				<span class="sr-only">Email aayush0325</span>
				<svg
					xmlns="http://www.w3.org/2000/svg"
					width="32"
					height="32"
					viewBox="0 0 24 24"
					><path
						fill="currentColor"
						d="M20 18h-2V9.51L12 13L6 9.51V18H4V6h1.2l6.8 4l6.8-4H20v12Z"
					></path></svg
				>
			</a>
			<a
				href="https://www.linkedin.com/in/aayush-khanna-633384290/"
				target="_blank"
			>
				<span class="sr-only">Follow aayush0325 on LinkedIn</span>
				<svg
					xmlns="http://www.w3.org/2000/svg"
					width="32"
					height="32"
					viewBox="0 0 24 24"
					><path
						fill="currentColor"
						d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77Z"
					></path></svg
				>
			</a>
			<a href="https://github.com/aayush0325" target="_blank">
				<span class="sr-only">Go to aayush0325's GitHub repo</span>
				<svg
					viewBox="0 0 16 16"
					aria-hidden="true"
					width="32"
					height="32"
					><path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path></svg
				>
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 1rem;
		z-index: 100;
		margin: 0 1rem;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.75rem 1.5rem;
		background-color: var(--bg-card);
		backdrop-filter: var(--glass);
		-webkit-backdrop-filter: var(--glass);
		border: 1px solid var(--border);
		border-radius: 100px;
		box-shadow: var(--shadow);
		max-width: 900px;
		margin: 0 auto;
	}
	h2 {
		margin: 0;
		font-size: 1.25rem;
		font-family: "Outfit", sans-serif;
	}
	h2 a {
		color: var(--text-main);
		font-weight: 800;
		letter-spacing: -0.01em;
	}
	.internal-links {
		display: flex;
		gap: 0.5rem;
	}
	.internal-links a {
		padding: 0.5rem 1rem;
		color: var(--text-muted);
		border-radius: 100px;
		transition: all 0.2s ease;
		font-weight: 500;
		font-size: 0.9375rem;
	}
	.internal-links a:hover {
		color: var(--text-main);
		background-color: var(--accent-light);
	}
	.internal-links a.active {
		color: var(--accent);
		background-color: var(--accent-light);
	}
	.social-links {
		display: flex;
		gap: 0.75rem;
	}
	.social-links a {
		display: flex;
		align-items: center;
		color: var(--text-muted);
		transition: color 0.2s ease;
	}
	.social-links a:hover {
		color: var(--accent);
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
		nav {
			padding: 0.5rem 1rem;
		}
		header {
			top: 0.5rem;
		}
	}
</style>
