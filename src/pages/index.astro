---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.intro {
				margin-bottom: 3rem;
			}
			h1 {
				font-size: 2rem;
				margin-bottom: 1.5rem;
			}
			.content {
				max-width: 600px;
			}
			.links {
				display: flex;
				gap: 1.5rem;
				margin-top: 2rem;
			}
			.links a {
				font-size: 0.9rem;
				color: var(--text-muted);
				text-transform: lowercase;
			}
			.links a:hover {
				color: var(--text-main);
				text-decoration: underline;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="intro">
				<h1>hi, i'm aayush</h1>
				<div class="content">
					<p>
						i'm aayush khanna, a passionate developer and sports
						enthusiast. here, i write about my ideas, experiences,
						and explorations - from deep tech to life beyond code.
					</p>
				</div>
				<div class="links">
					<a href="/blog">read my blog</a>
					<a href="/about">about me</a>
					<a href="https://github.com/aayush0325">github</a>
				</div>
			</section>

			<section class="featured">
				<h2>latest musings</h2>
				<p style="color: var(--text-muted); font-size: 0.9rem;">
					my recent/interesting blogs.
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>
